APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Virgülle ayrılmış origin listesi (ör. https://admin.sahana.app) — mobil
# istemci Bearer token kullandığı için buna ihtiyaç duymaz, sadece ileride
# eklenebilecek bir web paneli için. Boşsa hiçbir origin'e izin verilmez.
CORS_ALLOWED_ORIGINS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sahana
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Kullanıcı medyasının (avatar, gönderi görsel/videosu, takım logosu, sohbet
# sesi) gittiği disk. Local'de 'public' bırak. Prod'da Cloudflare R2'ye
# geçmek için 's3' yap + aşağıdaki AWS_* değerlerini R2 bilgileriyle doldur
# (R2, S3 API uyumlu — ayrı bir driver gerekmez). PRODUCTION-READINESS.md §C.
MEDIA_DISK=public

MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DATABASE=sahana_chat
# Lokalde auth kapalıysa boş bırak. Prod'da authorization: enabled ise
# doldurulmalı, yoksa "command find requires authentication" hatası alınır.
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
# Prod'da MAIL_MAILER=resend + RESEND_API_KEY (resend.com'da domain
# doğrulanıp API key alındıktan sonra) — config/services.php bunu okuyor.
RESEND_API_KEY=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# App Store/Play Store reviewer'ı için sabit OTP kodu — bu e-postaya kod
# maili hiç atılmaz, VerifyOtpCode sabit kodu kabul eder. İkisi de boşken
# devre dışı; sadece App Store Connect/Play Console'a review başvurusu
# yapılırken prod'da doldurulmalı. REVIEWER_DEMO_OTP_CODE tam 6 haneli
# olmalı (ör. 482913) — VerifyOtpRequest 'digits:6' doğrulaması yapıyor.
REVIEWER_DEMO_EMAIL=
REVIEWER_DEMO_OTP_CODE=

# MEDIA_DISK=s3 iken bu değerler R2 bucket'ının bilgileri olmalı:
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY  → R2 API token (Cloudflare
#   panelinde "R2 > Manage API Tokens")
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET  → R2 bucket adı
# AWS_URL     → bucket'ın herkese açık URL'i (R2.dev alt alanı ya da bağlı
#   custom domain) — ImageUploader::url() bunu doğrudan kullanıcıya döner
# AWS_ENDPOINT → https://<account-id>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true (R2 için zorunlu)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

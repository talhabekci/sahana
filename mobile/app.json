{
  "expo": {
    "name": "Sahana",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sahana",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.sahanaapp.app",
      "buildNumber": "8",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Sahana"
      }
    },
    "android": {
      "package": "com.sahanaapp.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B1F14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1F14",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Gönderine fotoğraf eklemek için galerine erişim gerekiyor.",
          "cameraPermission": "Gönderine fotoğraf çekmek için kameraya erişim gerekiyor."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Takım sohbetine sesli mesaj gönderebilmek için mikrofona erişim gerekiyor."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Yakınındaki oyuncu ve rakip ilanlarını gösterebilmek için konumuna erişim gerekiyor."
        }
      ],
      "expo-asset",
      "expo-video",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "sahana-zg"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9b753e5-70a6-45c9-86f1-37d46b6a8fdb"
      }
    },
    "owner": "talhabkc"
  }
}

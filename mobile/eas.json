{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
        "env": {
            "SENTRY_DISABLE_AUTO_UPLOAD": "true",
            "EXPO_PUBLIC_API_URL": "https://api.sahana-app.com/api/v1",
            "EXPO_PUBLIC_REVERB_HOST": "api.sahana-app.com",
            "EXPO_PUBLIC_REVERB_PORT": "443",
            "EXPO_PUBLIC_REVERB_SCHEME": "https"
        }
    }
  },
  "submit": {
    "production": {}
  }
}
